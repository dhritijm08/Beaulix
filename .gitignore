# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase config — tracked in version control (no secrets inside; uses /__/firebase/init.json)
# firebase.json is NOT ignored — it must be committed.

# Firebase service account keys — NEVER commit these.
# These grant full admin access to the Firebase project.
# ⚠  If you find one of these files in the repo, rotate the key IMMEDIATELY at:
#    https://console.cloud.google.com/iam-admin/serviceaccounts
# Store keys as Render env vars (GOOGLE_SERVICE_ACCOUNT_JSON) or Firebase Secrets only.
beaulix-model-*.json
*adminsdk*.json
*service-account*.json
*-firebase-adminsdk-*.json

# Uncomment if each developer uses a different Firebase project
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Grunt
.grunt/

# Bower
bower_components/

# Node
node_modules/
.npm/
.eslintcache
.node_repl_history
.lock-wscript
build/Release/
*.tgz
.yarn-integrity

# Environment variables
.env
.env.*
!.env.example

# Dataconnect
.dataconnect/

# Python virtual environments
.venv/
venv/
backend/venv/

# Python cache
__pycache__/
.pytest_cache/
*.py[cod]
*$py.class

# Training data and model artifacts
# Downloaded at build time via backend/download_data.py — never commit these.
# Run: git rm --cached backend/*.xlsx  (if accidentally tracked)
backend/*.xlsx
backend/dataset.csv
backend/models/*.pkl

# Colab audio assets — runtime files for the GPU server, not source code.
# Upload these to Google Drive or the Colab runtime directly.
# Run: git rm --cached colab/tune/*  (if accidentally tracked)
colab/tune/*.mp3
colab/tune/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Build outputs
dist/
build/
out/

# Temporary files
tmp/
temp/

# Misc
*.bak
*.swp
*.swo