rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config/gpu — ngrok GPU URL written by Colab on startup.
    // config/apiKey — ML backend API key, written once by admin/deploy script.
    // Both: authenticated users can read, no client writes allowed.
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // users/{userId}/history — each user can read/write only their own history.
    match /users/{userId}/history/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
