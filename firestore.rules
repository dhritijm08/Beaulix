rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config/gpu — ngrok GPU URL written by Colab on startup.
    // Authenticated users can read (needed by generator-init.js via getGpuUrl
    // Cloud Function). No client writes allowed.
    // NOTE: config/apiKey has been removed. The ML API key is now stored
    // exclusively as a Firebase Secret (BEAULIX_API_KEY) and is only accessible
    // to Cloud Functions — it never reaches the browser.
    match /config/{docId} {
      allow read: if request.auth != null && (docId == "gpu" || docId == "backend");
      allow write: if false;
    }

    // users/{userId}/history — each user can read/write only their own history.
    match /users/{userId}/history/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
