rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config/gpu — stores the current ngrok GPU URL written by Colab.
    // Any signed-in user can read it; client writes are blocked (Colab
    // writes via the Admin SDK which bypasses these rules).
    match /config/gpu {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
