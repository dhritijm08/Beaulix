rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config/gpu — ngrok GPU URL written by Colab on startup.
    // config/apiKey — ML backend API key, written once by admin/deploy script.
    // Both: authenticated users can read, no client writes allowed.
    // (Writes come from Colab Admin SDK or Firebase Console, which bypass rules.)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
