# Beaulix Backend — Environment Variables
# Copy this file to .env and fill in your values before deploying.
# Never commit .env to version control.

# ── Authentication ──────────────────────────────────────────────────────
# Required in production. All /predict and /predict-step2 endpoints are
# publicly accessible if this is not set. The server refuses to start in
# production mode (BEAULIX_ENV=production) without it.
BEAULIX_API_KEY=<secret-random-string>

# ── CORS / Frontend ─────────────────────────────────────────────────────
# Required in production. Must match your Firebase Hosting URL exactly.
# The server refuses to start in production mode without it.
# Example: https://your-project.web.app
BEAULIX_FRONTEND_URL=https://your-project.web.app

# ── Environment mode ────────────────────────────────────────────────────
# Set to "production" to enable startup-time enforcement of the two
# required variables above, and to disable dev-only CORS fallbacks.
# Leave unset (or set to anything else) for local development.
BEAULIX_ENV=production

# ── Cloudinary (avatar image uploads) ──────────────────────────────────
# Obtained from your Cloudinary dashboard or Firebase secrets.
# Required for avatar upload functionality in the frontend.
CLOUDINARY_CLOUD_NAME=<from-firebase-secrets>
CLOUDINARY_API_KEY=<from-firebase-secrets>
CLOUDINARY_API_SECRET=<from-firebase-secrets>

# ── Colab / GPU (sdxl_model.py) ─────────────────────────────────────────
# Directory on the Colab runtime where Beaulix music/audio assets are stored.
# Defaults to "/content" if not set. Only required when running the Colab GPU
# component — not needed for the FastAPI backend.
BEAULIX_MUSIC_DIR=/content
